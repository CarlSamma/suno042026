# SUNO Prompt Generator v2.0 - Environment Configuration
# Copy this file to .env and fill in your API keys
# =============================================================================

# =============================================================================
# OPENROUTER CONFIGURATION (Required for v2.0)
# =============================================================================
# Get your API key from: https://openrouter.ai/keys
# Minimum $5 credit required to start

# OpenRouter API Key - Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Default model for unspecified stages
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3-haiku

# Optional: Site identity for OpenRouter ranking
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=SUNO Prompt Generator

# =============================================================================
# LEGACY PROVIDER KEYS (Optional - for fallback if OpenRouter fails)
# =============================================================================
# These keys are no longer required but can be used as emergency fallback

# Last.fm API Key - Get from: https://www.last.fm/api/account/create
# Used for: Fetching user's recent tracks and music data
# LASTFM_API_KEY=your_lastfm_api_key_here

# Google AI API Key
# GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API Key
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key
# OPENAI_API_KEY=your_openai_api_key_here

# Mistral API Key
# MISTRAL_API_KEY=your_mistral_api_key_here

# DeepSeek API Key
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Perplexity API Key
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development

# Optional: Rate Limiting Configuration
MAX_REQUESTS_PER_MINUTE=60
PIPELINE_TIMEOUT_MS=180000

# Logging Configuration (optional)
LOG_TO_FILE=false
LOG_LEVEL=info

# =============================================================================
# COST ESTIMATES (OpenRouter pricing per 1M tokens)
# =============================================================================
# 
# BUDGET MODELS (Fast & Cheap)
# - google/gemini-1.5-flash: $0.05
# - deepseek/deepseek-chat: $0.02
# - meta-llama/llama-3-8b-instruct: $0.05
# - mistralai/mistral-7b-instruct: $0.10
# - anthropic/claude-3-haiku: $0.10
# - openai/gpt-4o-mini: $0.15
#
# BALANCED MODELS
# - anthropic/claude-3-sonnet: $3.00
# - google/gemini-1.5-pro: $1.00
# - mistralai/mistral-medium: $0.50
# - meta-llama/llama-3-70b-instruct: $0.80
#
# PREMIUM MODELS (Best Quality)
# - openai/gpt-4o: $3.00
# - google/gemini-1.5-pro-experimental: $7.00
# - anthropic/claude-3-opus: $15.00
#
# See all models: https://openrouter.ai/models
