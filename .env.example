# 🎵 SUNO Prompt Generator - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED API KEYS (Minimum needed for basic functionality)
# =============================================================================

# Last.fm API Key - Get it from: https://www.last.fm/api/account/create
# Used for: Fetching user's recent tracks and music data
LASTFM_API_KEY=your_lastfm_api_key_here

# Google AI Studio API Key - Get it from: https://makersuite.google.com/app/apikey
# Used for: Stage 1 (Analysis) - Deep musical analysis
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API Key - Get it from: https://console.anthropic.com/
# Used for: Stage 4 (Quality Control) - Prompt optimization
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key - Get it from: https://platform.openai.com/api-keys
# Used for: Stage 5 (Finalization) - Final Suno-compliant generation
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# OPTIONAL API KEYS (Enhances pipeline reliability with fallback providers)
# =============================================================================

# Mistral API Key - Get it from: https://console.mistral.ai/
# Used for: Stage 2 (Refinement) and fallback for Stage 1
MISTRAL_API_KEY=your_mistral_api_key_here

# DeepSeek API Key - Get it from: https://platform.deepseek.com/
# Used for: Stage 3 (Enhancement) - Creative musical enhancement
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Perplexity API Key - Get it from: https://docs.perplexity.ai/
# Used for: Additional research capabilities (currently not in main pipeline)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development

# Optional: Rate Limiting Configuration
MAX_REQUESTS_PER_MINUTE=60
PIPELINE_TIMEOUT_MS=180000

# Logging Configuration (optional)
LOG_TO_FILE=false
LOG_LEVEL=info

# =============================================================================
# API USAGE NOTES
# =============================================================================
# 
# COST ESTIMATES (per 1000 requests):
# - Google Gemini: ~$0.50-1.00
# - Anthropic Claude: ~$1.00-2.00  
# - OpenAI GPT-4: ~$2.00-5.00
# - Mistral: ~$0.50-1.00
# - DeepSeek: ~$0.10-0.50
# 
# RATE LIMITS:
# - Most providers: 60-100 requests/minute
# - Consider implementing caching for production use
#
# FALLBACK SYSTEM:
# - Each stage has a backup provider for reliability
# - Pipeline continues even if one provider fails